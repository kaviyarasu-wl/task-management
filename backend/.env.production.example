NODE_ENV=production
PORT=3000

# MongoDB (with auth)
MONGODB_URI=mongodb://root:CHANGE_ME@mongodb:27017/taskapp?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=CHANGE_ME
MONGO_DB_NAME=taskapp

# Redis (with auth)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# JWT (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_ADMIN_SECRET=CHANGE_ME_MIN_32_CHARS

# CORS
CORS_ORIGINS=https://yourdomain.com
TRUST_PROXY=true

# Logging
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn

# SMTP
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=your-email
SMTP_PASS=your-password
EMAIL_FROM=Task App <noreply@yourdomain.com>

# Backups
S3_BACKUP_BUCKET=your-backup-bucket
